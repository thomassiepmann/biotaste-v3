# ============================================
# Supabase Konfiguration
# ============================================
# Kopiere diese Datei zu .env und fülle die Werte aus

# Supabase Project URL
# Zu finden in: Supabase Dashboard > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key
# Zu finden in: Supabase Dashboard > Settings > API > Project API keys > anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# Wichtige Hinweise:
# ============================================
# 1. Erstelle eine .env Datei im Root-Verzeichnis
# 2. Kopiere die Werte aus dem Supabase Dashboard
# 3. Die .env Datei ist in .gitignore und wird NICHT committed
# 4. Für Production: Verwende Expo Secrets oder Environment Variables
