
# ============================================
# Supabase Konfiguration
# ============================================
# Kopiere diese Datei zu .env und fülle die Werte aus

# Supabase Project URL
# Zu finden in: Supabase Dashboard > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key
# Zu finden in: Supabase Dashboard > Settings > API > Project API keys > anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Lokales Backend für Healthcheck/Debug-Features
# Android Emulator: http://10.0.2.2:5000
# iOS Simulator:   http://localhost:5000
# Physisches Gerät: http://<WLAN-IP-DEINES-PC>:5000
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5000

# Optional für Node-CLI (z. B. scripts/weekly-draw.mjs)
# Falls nicht gesetzt, nutzt das Script EXPO_PUBLIC_* Fallbacks.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Nur für WRITE-Läufe nötig (dry-run funktioniert ohne Service-Role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Wichtige Hinweise:
# ============================================
# 1. Erstelle eine .env Datei im Root-Verzeichnis
# 2. Kopiere die Werte aus dem Supabase Dashboard
# 3. Die .env Datei ist in .gitignore und wird NICHT committed
# 4. Für Production: Verwende Expo Secrets oder Environment Variables
